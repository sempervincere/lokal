// prisma/schema.prisma
// LOKAL — Schema v2.2 (9 tables, includes co_earnings + cluster_proposals)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ────────────────────────────────────────────────

enum UserRole {
  BUSINESS_OWNER
  CLUSTER_OWNER
  ADMIN
}

enum SubsType {
  FREE
  EXPLORER
  OPERATOR
  AGENCY
}

enum ClusterStatus {
  SEEDING
  ACTIVE
  DEPRECATED
}

enum FieldStatus {
  PENDING
  VALIDATED
  REJECTED
}

enum SessionStatus {
  PENDING_PAYMENT
  PAYMENT_CONFIRMED
  GENERATING_REPORT
  ACTIVE
  EXPIRED
  FAILED
}

enum ReportStatus {
  PENDING
  GENERATING
  COMPLETE
  FAILED
}

enum CoEarningType {
  SESSION_SHARE
  FIELD_SUBMISSION
  REFRESH_BONUS
}

enum ProposalStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── SURVEY SYSTEM ENUMS ──────────────────────────────────────

enum SurveyResponseStatus {
  IN_PROGRESS
  SUBMITTED
  REVIEWED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ClaimStatus {
  PENDING
  DISTRIBUTED
  FAILED
}

enum VaultStatus {
  ACTIVE
  FROZEN
  CLOSED
}

// ─── USERS ────────────────────────────────────────────────

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  fullName      String   @map("full_name")
  role          UserRole @default(BUSINESS_OWNER)
  walletAddress String?  @unique @map("wallet_address")
  
  companyName   String?  @map("company_name")
  phoneNumber   String?  @map("phone_number")
  jobTitle      String?  @map("job_title")

  // ── KYC & profile fields (v2.2) ─────────────────────────────
  username       String?  @unique
  ktpHash        String?  @unique @map("ktp_hash")
  kycCompleted   Boolean  @default(false) @map("kyc_completed")
  referralSource String?  @map("referral_source")
  
  credits       Int      @default(0)
  isSubs        Boolean  @default(false) @map("is_subs")
  subsType      SubsType @default(FREE) @map("subs_type")

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  clusterOwner ClusterOwner?
  sessions     Session[]
  messages     Message[]

  @@map("users")
}

model ClusterOwner {
  id             String   @id @default(uuid())
  userId         String   @unique @map("user_id")
  coScore        Int      @default(0) @map("co_score")
  trustScore     Int      @default(60) @map("trust_score")
  nftMintAddress String?  @map("nft_mint_address")
  nftTxSignature String?  @map("nft_tx_signature")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")

  user       User        @relation(fields: [userId], references: [id])
  clusters   Cluster[]
  coEarnings CoEarning[]
  proposals  ClusterProposal[]

  @@map("cluster_owners")
}

model CoEarning {
  id          String        @id @default(uuid())
  coId        String        @map("co_id")
  type        CoEarningType
  amountIdrx  Decimal       @map("amount_idrx") @db.Decimal(18, 2)
  description String
  clusterId   String?       @map("cluster_id")
  sessionId   String?       @map("session_id")
  isPaid      Boolean       @default(false) @map("is_paid")
  paidAt      DateTime?     @map("paid_at")
  createdAt   DateTime      @default(now()) @map("created_at")

  clusterOwner ClusterOwner @relation(fields: [coId], references: [id])

  @@map("co_earnings")
}

// ─── CLUSTERS ─────────────────────────────────────────────

model Cluster {
  id                   String        @id @default(uuid())
  slug                 String        @unique
  name                 String
  description          String?
  ownerId              String        @map("owner_id")
  status               ClusterStatus @default(SEEDING)

  anchorLat            Float         @map("anchor_lat")
  anchorLng            Float         @map("anchor_lng")
  radiusKm             Float         @default(1.5) @map("radius_km")
  anchorLabel          String        @map("anchor_label")

  dataCompleteness     Int           @default(0) @map("data_completeness")
  confidenceScore      Int           @default(0) @map("confidence_score")
  totalValidatedFields Int           @default(0) @map("total_validated_fields")

  onchainSlug          String?       @map("onchain_slug")

  createdAt            DateTime      @default(now()) @map("created_at")
  updatedAt            DateTime      @updatedAt @map("updated_at")

  owner       ClusterOwner       @relation(fields: [ownerId], references: [id])
  fieldValues ClusterFieldValue[]
  sessions    Session[]
  surveyResponses SurveyResponse[]
  vault       ClusterVault?

  @@map("clusters")
}

// ─── CLUSTER PROPOSALS (v2.2) ───────────────────────────────

model ClusterProposal {
  id          String         @id @default(uuid())
  coId        String         @map("co_id")

  // ── Section 1: Area Legitimacy ────────────────────────────
  occupation        String
  areaDuration      String   @map("area_duration")
  primaryAnchor     String   @map("primary_anchor")
  physicalPresence  String   @map("physical_presence")
  sampleBusinesses  Json     @map("sample_businesses")

  // ── Section 2: Cluster Details ────────────────────────────
  clusterName        String  @map("cluster_name")
  clusterDescription String? @map("cluster_description")
  anchorType         String  @map("anchor_type")
  corridorDesc       String  @map("corridor_desc")
  anchorLat          Float   @map("anchor_lat")
  anchorLng          Float   @map("anchor_lng")
  anchorLabel        String  @map("anchor_label")
  radiusKm           Float   @default(1.5) @map("radius_km")

  // ── Metadata ──────────────────────────────────────────────
  status    ProposalStatus @default(PENDING)
  adminNote String?        @map("admin_note")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  clusterOwner ClusterOwner @relation(fields: [coId], references: [id])

  @@map("cluster_proposals")
}

// ─── FIELD VALUES ───────────────────────────────────────────

model ClusterFieldValue {
  id               String      @id @default(uuid())
  clusterId        String      @map("cluster_id")
  fieldCode        String      @map("field_code")
  fieldName        String      @map("field_name")
  tier             Int
  category         String
  collectionMethod String      @map("collection_method")
  isComplex        Boolean     @default(false) @map("is_complex")

  value            Json
  status           FieldStatus @default(PENDING)

  evidenceNote     String?     @map("evidence_note")
  evidencePhotoUrl String?     @map("evidence_photo_url")

  fieldHash      String?   @map("field_hash")
  solTxSignature String?   @map("sol_tx_signature")

  submittedAt  DateTime  @default(now()) @map("submitted_at")
  validatedAt  DateTime? @map("validated_at")

  cluster Cluster @relation(fields: [clusterId], references: [id])
  surveyFieldResponses SurveyFieldResponse[]

  @@unique([clusterId, fieldCode])
  @@map("cluster_field_values")
}

// ─── SESSIONS ─────────────────────────────────────────────

model Session {
  id             String        @id @default(uuid())
  userId         String        @map("user_id")
  clusterId      String        @map("cluster_id")

  status         SessionStatus @default(PENDING_PAYMENT)
  amountIdrx     Decimal       @default(400000) @map("amount_idrx") @db.Decimal(18, 2)
  solTxSignature String?       @unique @map("sol_tx_signature")

  freeMessageCount Int @default(0) @map("free_message_count")

  activatedAt DateTime? @map("activated_at")
  expiresAt   DateTime? @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  user        User         @relation(fields: [userId], references: [id])
  cluster     Cluster      @relation(fields: [clusterId], references: [id])
  conceptForm ConceptForm?
  report      Report?
  messages    Message[]

  @@map("sessions")
}

model ConceptForm {
  id                 String   @id @default(uuid())
  sessionId          String   @unique @map("session_id")

  fbSubcategory      String   @map("fb_subcategory")
  conceptName        String   @map("concept_name")
  conceptDescription String   @map("concept_description")
  targetCustomer     String   @map("target_customer")
  specificQuestions  String?  @map("specific_questions")
  menuItems          Json     @map("menu_items")

  submittedAt DateTime @default(now()) @map("submitted_at")

  session Session @relation(fields: [sessionId], references: [id])

  @@map("concept_forms")
}

model Report {
  id               String       @id @default(uuid())
  sessionId        String       @unique @map("session_id")
  status           ReportStatus @default(PENDING)

  sections         Json?

  pdfUrl           String?  @map("pdf_url")
  tokensUsed       Int?     @map("tokens_used")
  generationTimeMs Int?     @map("generation_time_ms")
  errorMessage     String?  @map("error_message")
  retryCount       Int      @default(0) @map("retry_count")

  createdAt   DateTime  @default(now()) @map("created_at")
  completedAt DateTime? @map("completed_at")

  session Session @relation(fields: [sessionId], references: [id])

  @@map("reports")
}

model Message {
  id         String  @id @default(uuid())
  sessionId  String? @map("session_id")
  userId     String  @map("user_id")
  clusterId  String  @map("cluster_id")

  role       String
  content    String   @db.Text
  isFree     Boolean  @default(true) @map("is_free")
  messageNum Int?     @map("message_num")

  createdAt DateTime @default(now()) @map("created_at")

  session Session? @relation(fields: [sessionId], references: [id])
  user    User     @relation(fields: [userId], references: [id])

  @@map("messages")
}

// ─── SURVEY SYSTEM ──────────────────────────────────────────

model SurveyResponse {
  id               String              @id @default(uuid())
  clusterId        String              @map("cluster_id")
  formToken        String              @map("form_token")
  respondentWallet String              @map("respondent_wallet")
  respondentEmail  String?             @map("respondent_email")

  status           SurveyResponseStatus @default(IN_PROGRESS)
  submittedAt      DateTime?           @map("submitted_at")
  reviewedAt       DateTime?           @map("reviewed_at")

  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")

  cluster         Cluster              @relation(fields: [clusterId], references: [id])
  fieldResponses  SurveyFieldResponse[]
  vaultClaim      VaultClaim?

  @@unique([clusterId, formToken])
  @@index([respondentWallet])
  @@index([clusterId])
  @@map("survey_responses")
}

model SurveyFieldResponse {
  id               String       @id @default(uuid())
  surveyResponseId String       @map("survey_response_id")
  fieldCode         String       @map("field_code")
  value             Json

  // CO review per field
  coStatus          ReviewStatus @default(PENDING) @map("co_status")
  coRejectReason    String?      @map("co_reject_reason")
  reviewedAt        DateTime?    @map("reviewed_at")

  // If approved, link to aggregated field value
  clusterFieldValueId String?   @map("cluster_field_value_id")

  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  surveyResponse    SurveyResponse @relation(fields: [surveyResponseId], references: [id], onDelete: Cascade)
  clusterFieldValue ClusterFieldValue? @relation(fields: [clusterFieldValueId], references: [id])

  @@unique([surveyResponseId, fieldCode])
  @@index([fieldCode])
  @@index([coStatus])
  @@map("survey_field_responses")
}

// ─── VAULT SYSTEM ──────────────────────────────────────────

model ClusterVault {
  id              String      @id @default(uuid())
  clusterId       String      @unique @map("cluster_id")
  totalPool       Decimal     @default(0) @map("total_pool") @db.Decimal(18, 2)
  distributed     Decimal     @default(0) @map("distributed") @db.Decimal(18, 2)
  respondentCount Int         @default(0) @map("respondent_count")
  status          VaultStatus @default(ACTIVE)

  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  cluster Cluster @relation(fields: [clusterId], references: [id])
  claims  VaultClaim[]

  @@map("cluster_vaults")
}

model VaultClaim {
  id                String      @id @default(uuid())
  vaultId           String      @map("vault_id")
  surveyResponseId  String      @unique @map("survey_response_id")
  respondentWallet  String      @map("respondent_wallet")
  fieldCodes        String[]    @map("field_codes")
  approvedCount     Int         @default(0) @map("approved_count")
  amount            Decimal     @map("amount") @db.Decimal(18, 2)
  status            ClaimStatus @default(PENDING)
  distributedAt     DateTime?   @map("distributed_at")
  solTxSignature    String?     @map("sol_tx_signature")

  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  vault             ClusterVault @relation(fields: [vaultId], references: [id])
  surveyResponse    SurveyResponse @relation(fields: [surveyResponseId], references: [id])

  @@index([respondentWallet])
  @@index([vaultId])
  @@map("vault_claims")
}

// ─── WAITLIST ──────────────────────────────────────────────

enum WaitlistRole {
  BUSINESS_OWNER
  CLUSTER_OWNER
}

model WaitlistSubmission {
  id        String       @id @default(uuid())
  email     String       @unique
  role      WaitlistRole
  city      String?
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  @@map("waitlist_submissions")
}
